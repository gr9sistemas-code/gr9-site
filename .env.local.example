# ============================================================
# GR9 Sistemas — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o arquivo .env.local com valores reais.
# ============================================================

# --- Pipedrive CRM ---
# Token de API do Pipedrive (Settings > Personal preferences > API)
PIPEDRIVE_API_TOKEN=seu_token_aqui

# ID do pipeline onde os deals serão criados
# Encontre em: Pipedrive > Pipelines > URL da página
PIPEDRIVE_PIPELINE_ID=1

# ID do estágio inicial dos deals no pipeline
# Encontre via API: GET /v1/stages?pipeline_id=SEU_PIPELINE_ID
PIPEDRIVE_STAGE_ID=1

# --- API URL (apenas para export estático) ---
# Se usar output: 'export' no next.config.js, aponte para a URL da sua API externa.
# Deixe em branco para usar a API route interna (/api/leads).
# NEXT_PUBLIC_API_URL=https://sua-api.vercel.app

# --- Google Ads (Conversão) ---
# ID da conta Google Ads (formato: AW-XXXXXXXXX)
# Encontre em: Google Ads > Ferramentas > Acompanhamento de conversões
NEXT_PUBLIC_GOOGLE_ADS_ID=
# ID completo da conversão (formato: AW-XXXXXXXXX/AbCdEfGhIjK)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION=

# --- Meta Pixel (Facebook/Instagram Ads) ---
# ID do Pixel (formato: número de 15-16 dígitos)
# Encontre em: Meta Business Suite > Gerenciador de Eventos
NEXT_PUBLIC_META_PIXEL_ID=
